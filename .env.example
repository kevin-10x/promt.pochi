# Copy this file to .env and fill in your real values.
# Get these from https://developer.safaricom.co.ke after creating an app.

# --- Daraja app credentials (from your app's "Keys" tab) ---
CONSUMER_KEY=your_consumer_key_here
CONSUMER_SECRET=your_consumer_secret_here

# --- Your Till / PayBill details ---
# BusinessShortCode: your Till number (Buy Goods) or PayBill number
BUSINESS_SHORT_CODE=174379
# Passkey: from Daraja portal, under Lipa Na M-Pesa Online > Passkey
PASSKEY=your_passkey_here

# Use "CustomerBuyGoodsOnline" for a Till/Pochi la Biashara number,
# or "CustomerPayBillOnline" for a PayBill number.
TRANSACTION_TYPE=CustomerBuyGoodsOnline

# --- Environment ---
# "sandbox" for testing, "production" for real money
DARAJA_ENV=sandbox

# Publicly reachable HTTPS URL where Safaricom will POST the payment result.
# Must be a live server (not localhost) - use ngrok for local testing.
CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

PORT=3000
